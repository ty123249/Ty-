local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")

local AttackRemote = RS:WaitForChild("E&F"):WaitForChild("Attack"):WaitForChild("AttackOtherRE")

local AttackTab = Window:CreateTab("攻擊玩家", 4483362458)

local attackSpeed = 0.15
local attackDamage = 1.0e30

_G.AutoAttackAll = false

AttackTab:CreateSection("全體攻擊設定")

AttackTab:CreateInput({
   Name = "攻擊速度 (秒)",
   PlaceholderText = "輸入速度",
   CurrentValue = tostring(attackSpeed),
   Callback = function(v)
      local n = tonumber(v)
      if n then
         attackSpeed = n
      end
end,})

AttackTab:CreateInput({
   Name = "攻擊傷害",
   PlaceholderText = "輸入傷害",
   CurrentValue = tostring(attackDamage),
   Callback = function(v)
      local n = tonumber(v)
      if n then
         attackDamage = n
      end
end,})

AttackTab:CreateToggle({
   Name = "持續攻擊全部玩家",
   CurrentValue = false,
   Callback = function(v)
      _G.AutoAttackAll = v end,})

task.spawn(function()

   while true do

      if _G.AutoAttackAll then

         local targets = {}

         for _,plr in pairs(Players:GetPlayers()) do
            if plr ~= Players.LocalPlayer and plr.Character then
               table.insert(targets, plr.Character)
            end
         end

         if Players.LocalPlayer.Character and Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then

            local args = {
               targets,
               {AttackerCFrame = Players.LocalPlayer.Character.HumanoidRootPart.CFrame,
                AttackType = "Skill",
                Damage = attackDamage}}

            AttackRemote:FireServer(unpack(args))
        end
    end
        task.wait(attackSpeed)
   end
end)


