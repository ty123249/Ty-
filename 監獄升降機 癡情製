local trainAmount = 6

_G.AutoTrain = false
Tab:CreateToggle({
   Name = "自動訓練",
   CurrentValue = false,
   Flag = "AutoTrainToggle",
   Callback = function(Value)
      _G.AutoTrain = Value
      Rayfield:Notify({
