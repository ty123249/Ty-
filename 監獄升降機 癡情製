   Callback = function(Text)
      local num = tonumber(Text)
      if num and num > 0 then
         trainAmount = num
         Rayfield:Notify({
            Title = "數值更新",
            Content = "訓練每次改成: " .. trainAmount,
            Duration = 4})
      else
         Rayfield:Notify({
            Title = "無效輸入",
