OtherTab:CreateSection("自動開箱設定")

local AutoOpenChest = false
local chestAmount = 1

OtherTab:CreateInput({
    Name = "開箱數量(1~10)",
    PlaceholderText = "輸入數字",
    CurrentValue = "1",
    Callback = function(v)
        local n = tonumber(v)
        if n then
            if n < 1 then n = 1 end
            if n > 10 then n = 10 end
            chestAmount = n
        end
    end})

OtherTab:CreateToggle({
    Name = "自動開箱",
    CurrentValue = false,
    Callback = function(v)
        AutoOpenChest = v

        if AutoOpenChest then
            task.spawn(function()
                local RS = game:GetService("ReplicatedStorage")
                local DoLuck = RS:WaitForChild("E&F"):WaitForChild("Equipment"):WaitForChild("DoLuckRF")
                
                for i = 1, chestAmount do
                    local args = {"neck", "Event1", 1}
                    pcall(function()
                        DoLuck:InvokeServer(unpack(args))
                    end)
                    task.wait(0.1)
                end

                AutoOpenChest = false
            end)
        end
    end})


