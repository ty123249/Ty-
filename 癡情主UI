    hpLabel = Instance.new("TextLabel")
    hpLabel.Size = UDim2.new(1, 0, 1, 0)
    hpLabel.BackgroundTransparency = 1
    hpLabel.TextColor3 = Color3.fromRGB(255, 0, 0)
    hpLabel.Font = Enum.Font.SourceSansBold
    hpLabel.TextScaled = true
    hpLabel.Parent = healthGui
    local function updateHP()
        if humanoid then
            hpLabel.Text = math.max(0, math.floor(humanoid.Health)) .. " / " .. math.floor(humanoid.MaxHealth)
        else
            hpLabel.Text = "0 / 0"
        end
    end

    updateHP()
    healthConn = humanoid.HealthChanged:Connect(updateHP)
end

