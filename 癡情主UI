local function refreshPlayers()
    PlayerCountLabel.Text = "服務器人數: "..#Players:GetPlayers()

    local playersList = Players:GetPlayers()

    table.sort(playersList, function(a, b)
        local aTime = newPlayers[a] or 0
        local bTime = newPlayers[b] or 0
        return aTime < bTime
    end)

    local index = 1
    for _, player in ipairs(playersList) do
        if not playerEntries[player] then
            createPlayerEntry(player, index)
        else
            playerEntries[player].entry.LayoutOrder = index
        end
        index += 1
    end

    for p, data in pairs(playerEntries) do
        if not p.Parent then
            data.entry:Destroy()
            playerEntries[p] = nil
        end
    end

    updateCanvasSize()
end

