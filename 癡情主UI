local function showTargetHealth(player, offsetY)
    hideTargetHealth()

    if not player or not player.Character then return end
    local char = player.Character
    local humanoid = char:FindFirstChild("Humanoid")
    local part = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso") or char:FindFirstChild("HumanoidRootPart")
    if not humanoid or not part then return end

    healthGui = Instance.new("BillboardGui")
    healthGui.Size = UDim2.new(0, 120, 0, 40)
    healthGui.StudsOffset = Vector3.new(0, offsetY or 2, 0)
