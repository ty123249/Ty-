local function colorForce(text,r,g,b)
    text = tostring(text)
    text = text:gsub("&","&amp;")
    text = text:gsub("<","&lt;")
    text = text:gsub(">","&gt;")
    return string.format("<font color='rgb(%d,%d,%d)'>%s</font>", r,g,b, text)
end

