loopLockBackNoTeamBtn.MouseButton1Click:Connect(function()
    isLoopLockBackNoTeam = not isLoopLockBackNoTeam
    loopLockBackNoTeamBtn.Text = "循環鎖敵人: "..(isLoopLockBackNoTeam and "開" or "關")

    if not isLoopLockBackNoTeam then
        if renderConn then
            renderConn:Disconnect()
            renderConn = nil
        end
        stopLoopLockBack()
        return
    end

    task.spawn(function()
        local enemyIndex = 1

        while isLoopLockBackNoTeam do
            targetPlayer = nil
            local myChar = Player.Character
            local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")

            local enemies = {}
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= Player
                and p.Character
                and p.Character:FindFirstChild("Humanoid")
                and p.Character:FindFirstChild("HumanoidRootPart")
                and Player.Team ~= nil
                and p.Team ~= Player.Team
                and p.Character.Humanoid.FloorMaterial ~= Enum.Material.Air
                and p.Character.HumanoidRootPart.Position.Y > -50 then
                    table.insert(enemies, p)
                end
            end

            if #enemies == 0 then
                if renderConn then
                    renderConn:Disconnect()
                    renderConn = nil
                end
                task.wait(0.2)
            else
                if enemyIndex > #enemies then enemyIndex = 1 end
                local p = enemies[enemyIndex]
                enemyIndex = enemyIndex + 1

                targetPlayer = p
                showTargetHealth(p, 2)
                local tRoot = p.Character.HumanoidRootPart

                if myRoot and tRoot then
                    if renderConn then
                        renderConn:Disconnect()
                        renderConn = nil
                    end

                    renderConn = RunService.RenderStepped:Connect(function()
                        if not isLoopLockBackNoTeam then return end
                        if not myRoot.Parent or not tRoot.Parent or tRoot.Position.Y < -50 then return end

                        local safeOffset = Vector3.new(0, 3, 0)
                        for _, enemy in ipairs(enemies) do
                            if enemy ~= Player
                            and enemy.Character
                            and enemy.Character:FindFirstChild("HumanoidRootPart")
                            and enemy.Team ~= Player.Team then
                                local dist = (enemy.Character.HumanoidRootPart.Position - myRoot.Position).Magnitude
                                if dist < 5 then
                                    myRoot.CFrame = CFrame.new(myRoot.Position + safeOffset)
                                end
                            end
                        end

                        
                        myRoot.CFrame = tRoot.CFrame * CFrame.new(0,0,3)
                        workspace.CurrentCamera.CFrame = CFrame.new(
                            myRoot.Position + Vector3.new(0,2,0),
                            tRoot.Position + Vector3.new(0,2,0))
                    end)
                end

                task.wait(tonumber(loopIntervalInput.Text) or 1)
            end
        end

        stopLoopLockBack()
    end)
end)

