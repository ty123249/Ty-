local function CleanupAimbot()
    AimbotEnabled = false

    if MainLoop then
        MainLoop:Disconnect()
        MainLoop = nil
    end

    if FOVring then
        FOVring.Visible = false
        FOVring:Remove()
        FOVring = nil
    end
end

local function GetClosestTarget()
    local closestPlayer = nil
    local shortestDistance = 150

    for _, v in pairs(Players:GetPlayers()) do
        if v ~= Players.LocalPlayer and v.Character and v.Character:FindFirstChild("Head") and v.Character.Humanoid.Health > 0 then
            local pos, onScreen = Cam:WorldToViewportPoint(v.Character.Head.Position)
            if onScreen then
                local distance = (Vector2.new(pos.X, pos.Y) - (Cam.ViewportSize / 2)).Magnitude
                if distance < shortestDistance then
                    closestPlayer = v
                    shortestDistance = distance
                end
            end
        end
    end
    return closestPlayer
end

