local function createToggle(name)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(1,-10,0,30)
	btn.BackgroundColor3 = Color3.fromRGB(70,70,70)
	btn.TextColor3 = colors[math.random(1,#colors)]
	btn.Text = name.." [OFF]"
	btn.Parent = scrollingFrame
	local state=false
	btn.MouseButton1Click:Connect(function()
		state=not state
		btn.Text=name.." ["..(state and "ON" or "OFF").."]"
		btn.TextColor3 = colors[math.random(1,#colors)]
	end)
	return function() return state end, btn
end

local function createSpeedControl(btn, default)
	local posY = btn.Position.Y.Offset + btn.Size.Y.Offset + 5
	local box = Instance.new("TextBox")
	box.Size = UDim2.new(0,50,0,25)
	box.Position = UDim2.new(0,5,0,posY)
	box.Text = tostring(default)
	box.ClearTextOnFocus = false
	box.Parent = scrollingFrame

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(0,100,0,25)
	label.Position = UDim2.new(0,60,0,posY)
	label.Text = "速度: "..default
	label.TextColor3 = colors[math.random(1,#colors)]
	label.BackgroundTransparency = 1
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Parent = scrollingFrame

	return box, label
end

local function createFeature(name, hasSpeed, defaultSpeed)
	local toggleFunc, btn = createToggle(name)
	btn.Position = UDim2.new(0,5,0,yOffset)
	yOffset = yOffset + btn.Size.Y.Offset + 5
	
	local box, label
	if hasSpeed then
		box, label = createSpeedControl(btn, defaultSpeed)
		yOffset = yOffset + box.Size.Y.Offset + 5
	end
	
	return toggleFunc, box, label
end

