local function CreateLabelInput(labelText, defaultValue, yPos, callback)
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0,120,0,20)
    label.Position = UDim2.new(0,10,0,yPos)
    label.BackgroundTransparency = 1
    if labelText == "攻擊時間: " then
        label.Text = labelText..string.format("%.2f", defaultValue)
    else
        label.Text = labelText..string.format("%.2e", defaultValue)
    end
    label.TextColor3 = Color3.fromRGB(255,255,255)
    label.Font = Enum.Font.SourceSansBold
    label.TextScaled = true
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = contentFrame

    local input = Instance.new("TextBox")
    input.Size = UDim2.new(0,80,0,20)
    input.Position = UDim2.new(0,140,0,yPos)
    input.Text = tostring(defaultValue)
    input.ClearTextOnFocus = false
    input.TextColor3 = Color3.fromRGB(0,0,0)
    input.BackgroundColor3 = Color3.fromRGB(200,200,200)
    input.Font = Enum.Font.SourceSans
    input.TextScaled = true
    input.Parent = contentFrame
    input.FocusLost:Connect(function()
        local val = tonumber(input.Text)
        if not val then
            input.Text = tostring(defaultValue)
            if labelText == "攻擊時間: " then
                label.Text = labelText..string.format("%.2f", defaultValue)
            else
                label.Text = labelText..string.format("%.2e", defaultValue)
            end
            return
        end

        callback(val)
        if labelText == "攻擊時間: " then
            label.Text = labelText..string.format("%.2f", val)
        else
            label.Text = labelText..string.format("%.2e", val)
        end
    end)
end

