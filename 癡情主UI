                dragging=true
                dragOffset=Vector2.new(input.Position.X-gui.AbsolutePosition.X,input.Position.Y-gui.AbsolutePosition.Y)
                input.Changed:Connect(function()
                    if input.UserInputState==Enum.UserInputState.End then dragging=false end
                end)
            end
        end)
        bar.InputChanged:Connect(function(input)
            if input.UserInputType==Enum.UserInputType.MouseMovement or input.UserInputType==Enum.UserInputType.Touch then dragInput=input end
        end)
        RunService.RenderStepped:Connect(function()
            if dragging and dragInput then
                local pos = dragInput.Position or UserInputService:GetMouseLocation()
                gui.Position=UDim2.new(0,pos.X-dragOffset.X,0,pos.Y-dragOffset.Y)
            end
        end)
    end

