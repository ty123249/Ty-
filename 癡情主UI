local function formatKeyName(str)
    str = str:gsub("%s+", "")
    if #str == 0 then return nil end
    return str:sub(1,1):upper() .. str:sub(2)
end

-- 同步文字
keyInput:GetPropertyChangedSignal("Text"):Connect(function()
    simBtn.Text = keyInput.Text:upper()
end)

local function doPress(keycode)
    pcall(function()
        VirtualUser:CaptureController()
        VirtualUser:SetKeyDown(keycode.Value)
    end)
    pcall(function()
        local input = Instance.new("InputObject")
        input.KeyCode = keycode
        input.UserInputType = Enum.UserInputType.Keyboard
        UserInputService.InputBegan:Fire(input, false)
    end)
end

local function doRelease(keycode)
    pcall(function()
        VirtualUser:SetKeyUp(keycode.Value)
    end)
    pcall(function()
        local input = Instance.new("InputObject")
        input.KeyCode = keycode
        input.UserInputType = Enum.UserInputType.Keyboard
        UserInputService.InputEnded:Fire(input, false)
    end)
end

