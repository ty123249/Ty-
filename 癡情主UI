local function clearESP()
    for i = #_G.LaToolsObjects, 1, -1 do
        local obj = _G.LaToolsObjects[i]
        if obj and obj.Parent then
            pcall(function() obj:Destroy() end)
        end
        table.remove(_G.LaToolsObjects, i)
    end

    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Model") then
            obj:SetAttribute("LaESPAttached", nil)
        end
    end
end

local function clearPlayerESP(character)
    if not character then return end
    character:SetAttribute("LaESPAttached", nil)
    for _, v in ipairs(character:GetChildren()) do
        if v:IsA("Highlight") then
            pcall(function() v:Destroy() end)
        end
    end
end

local function hideGameName(player, hide)
    if player and player.Character then
        local h = player.Character:FindFirstChildOfClass("Humanoid")
        if h then
            h.DisplayDistanceType = hide
                and Enum.HumanoidDisplayDistanceType.None
                or Enum.HumanoidDisplayDistanceType.Viewer
        end
    end
end

local function detectEntity(model)
    local humanoid = model:FindFirstChildOfClass("Humanoid")
    local player = Players:GetPlayerFromCharacter(model)
    if player then return "Player" end
    if not humanoid then return "Robot" end

    local hasAI = false
    for _, v in ipairs(model:GetDescendants()) do
        if v:IsA("Script") or v:IsA("ModuleScript") then
            hasAI = true
            break
        end
    end

    local seenDamage = false
    local lastHp = humanoid.Health
    humanoid:GetPropertyChangedSignal("Health"):Connect(function()
        if humanoid.Health < lastHp then
            seenDamage = true
        end
        lastHp = humanoid.Health
    end)

    if hasAI then
        if humanoid.MaxHealth >= 100 or seenDamage then
            return "Monster"
        end
        return "Robot"
    else
        return "Robot"
    end
end

local function createESP(model)
    if model:GetAttribute("LaESPAttached") then return end
    model:SetAttribute("LaESPAttached", true)

    local humanoid = model:FindFirstChildOfClass("Humanoid")
    local hrp = model:FindFirstChild("HumanoidRootPart") or model:FindFirstChild("Head") or model.PrimaryPart
    if not humanoid or not hrp then return end
    local player = Players:GetPlayerFromCharacter(model)
    if player then
        humanoid.Died:Connect(function()
            clearPlayerESP(model)
        end)
    end

    local billboard = Instance.new("BillboardGui")
    billboard.Adornee = hrp
    billboard.Size = UDim2.new(0, 200, 0, 50)
    billboard.StudsOffset = Vector3.new(0, 4, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = espFolder
    table.insert(_G.LaToolsObjects, billboard)

    local tagLabel = Instance.new("TextLabel")
    tagLabel.Size = UDim2.new(1,0,0.3,0)
    tagLabel.BackgroundTransparency = 1
    tagLabel.Font = Enum.Font.SourceSansBold
    tagLabel.TextSize = 16
    tagLabel.Parent = billboard

    local infoLabel = Instance.new("TextLabel")
    infoLabel.Size = UDim2.new(1,0,0.7,0)
    infoLabel.Position = UDim2.new(0,0,0.3,0)
    infoLabel.BackgroundTransparency = 1
    infoLabel.Font = Enum.Font.SourceSansBold
    infoLabel.TextSize = 16
    infoLabel.TextColor3 = Color3.fromRGB(255,255,255)
    infoLabel.Parent = billboard

    local highlight = Instance.new("Highlight")
    highlight.FillTransparency = 1
    highlight.OutlineColor = Color3.fromRGB(255,255,255)
    highlight.Adornee = model
    highlight.Parent = model
    table.insert(_G.LaToolsObjects, highlight)

    local conn
    conn = RunService.RenderStepped:Connect(function()
        if not model.Parent or humanoid.Health <= 0 then
            pcall(function()
                billboard:Destroy()
                highlight:Destroy()
            end)
            model:SetAttribute("LaESPAttached", nil)
            conn:Disconnect()
            return
        end

        if not _G.LaToolsState.ESP then
            billboard.Enabled = false
            highlight.Enabled = false
            hideGameName(player, false)
            return
        end

        local hrpLocal = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        local distance = hrpLocal and math.floor((hrpLocal.Position - hrp.Position).Magnitude) or 0

        local entityType = detectEntity(model)
        local tag = "[機器人]"
        local color = Color3.fromRGB(128,128,128)

        if entityType == "Player" then
            tag = "[玩家]"
            color = Color3.fromRGB(255,255,0)
            hideGameName(player, true)
        elseif entityType == "Monster" then
            tag = "[怪物]"
            color = Color3.fromRGB(255,0,0)
        end

        tagLabel.Text = tag
        tagLabel.TextColor3 = color
        infoLabel.Text = string.format("%s | 血量:%d/%d | 距離:%d格",
            model.Name, humanoid.Health, humanoid.MaxHealth, distance)

        billboard.Enabled = true
        highlight.Enabled = true
    end)
end
local function setupESP(model)
    task.spawn(function()
        local humanoid, hrp
        local tries = 0
        repeat
            humanoid = model:FindFirstChildOfClass("Humanoid") or model:WaitForChild("Humanoid",1)
            hrp = model:FindFirstChild("HumanoidRootPart") or model:FindFirstChild("Head") or model.PrimaryPart
            tries += 1
            task.wait(0.1)
        until (humanoid and hrp) or tries >= 50
        if humanoid and hrp and model ~= LocalPlayer.Character then
            createESP(model)
        end
    end)
end

local function bindPlayerESP(player)
    if player == LocalPlayer then return end
    if player.Character then
        clearPlayerESP(player.Character)
        setupESP(player.Character)
    end
    player.CharacterAdded:Connect(function(char)
        task.wait(0.2)
        clearPlayerESP(char)
        setupESP(char)
    end)
end

local function toggleESP(state)
    _G.LaToolsState.ESP = state
    clearESP()
    if state then
        for _, p in ipairs(Players:GetPlayers()) do
            bindPlayerESP(p)
        end
        
        Players.PlayerAdded:Connect(bindPlayerESP)
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("Model") and obj ~= LocalPlayer.Character then
                setupESP(obj)
            end
        end

        workspace.DescendantAdded:Connect(function(obj)
            if not _G.LaToolsState.ESP then return end
            if obj:IsA("Model") and obj ~= LocalPlayer.Character then
                setupESP(obj)
            end
        end)
    else
        for _, p in ipairs(Players:GetPlayers()) do
            hideGameName(p, false)
            if p.Character then
                clearPlayerESP(p.Character)
            end
        end
        clearESP()
    end
end

