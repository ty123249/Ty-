local function FormatValue(val)
    if name=="時間" or name=="大氣效果" or name:find("開關") then
        return tostring(math.floor(val + 0.5))
    else
        return string.format("%.1f", math.floor(val*10)/10)
    end
end

local function UpdateValue(val)
    val = math.clamp(val, -2147483647, 2147483647)
    local displayVal = FormatValue(val)
    Input.Text = displayVal
    Label.Text = string.format("%s：%s", name, displayVal)
    return val
end

local function ApplyValue(val)
    val = tonumber(val) or 0
    if name=="亮度" then
        Lighting.Brightness = val
    elseif name=="環境光" then
        Lighting.Ambient = Color3.fromRGB(val,val,val)
    elseif name=="戶外光" then
        Lighting.OutdoorAmbient = Color3.fromRGB(val,val,val)
    elseif name=="時間" then
        val = val % 24
        Lighting.ClockTime = val
    elseif name=="霧起始" then
        Lighting.FogStart = val
    elseif name=="霧結束" then
        Lighting.FogEnd = val
    elseif name=="陰影強度" then
        Lighting.ShadowSoftness = math.clamp(val/100,0,1)
    elseif name=="大氣效果" then
        val = val>=1 and 1 or 0
        local Atmos = Lighting:FindFirstChildOfClass("Atmosphere")
        if val==1 and not Atmos then
            local AtmosClone = Instance.new("Atmosphere")
            AtmosClone.Parent = Lighting
        elseif val==0 and Atmos then
            Atmos:Destroy()
        end
            
    elseif name=="霧顏色" then
        Lighting.FogColor = Color3.fromRGB(val,val,val)
    elseif name=="角色亮度" then
        if LocalPlayer.Character then
            for _, part in pairs(LocalPlayer.Character:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.LocalTransparencyModifier = 1 - val/100
                end
            end
        end
        
    elseif name=="角色顏色" then
        if LocalPlayer.Character then
            for _, part in pairs(LocalPlayer.Character:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.Color = Color3.fromRGB(val,val,val)
                end
            end
        end
        
    elseif name=="角色反射" then
        if LocalPlayer.Character then
            for _, part in pairs(LocalPlayer.Character:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.Reflectance = val/100
                end
            end
        end
        
    elseif name=="角色材質" then
        if LocalPlayer.Character then
            for _, part in pairs(LocalPlayer.Character:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.Material = Enum.Material[val] or part.Material
                end
            end
        end
        
    elseif name=="角色大小" then
        if LocalPlayer.Character then
            for _, part in pairs(LocalPlayer.Character:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.Size = Vector3.new(val,val,val)
                end
            end
        end

    elseif name=="物件亮度" then
        for _, part in pairs(Workspace:GetDescendants()) do
            if part:IsA("BasePart") then
                part.LocalTransparencyModifier = 1 - val/100
            end
        end
    elseif name=="物件顏色" then
        for _, part in pairs(Workspace:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Color = Color3.fromRGB(val,val,val)
            end
        end
    elseif name=="物件反射" then
        for _, part in pairs(Workspace:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Reflectance = val/100
            end
        end
    elseif name=="物件材質" then
        for _, part in pairs(Workspace:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Material = Enum.Material[val] or part.Material
            end
        end
    elseif name=="物件大小" then
        for _, part in pairs(Workspace:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Size = Vector3.new(val,val,val)
            end
        end
    end

    UpdateValue(val)
end

