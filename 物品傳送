-- 4. 點擊錄入邏輯 (智慧過濾)
mouse.Button1Down:Connect(function()
	if not isRecording then return end
	local target = mouse.Target
	if not target or target:IsDescendantOf(player.Character) then return end

	local nameToAdd = ""
	if selectMode == "Model" then
		local model = target:FindFirstAncestorOfClass("Model")
		if model then nameToAdd = model.Name end
	else
		nameToAdd = target.Name
	end

	if nameToAdd ~= "" then
		local currentText = inputBox.Text
		if currentText == "" then 
			inputBox.Text = nameToAdd
		elseif not string.find(currentText, nameToAdd) then
			inputBox.Text = currentText .. "," .. nameToAdd
		end
	end
end)

-- 5. 核心瞬移函數 (不破壞錨定結構)
local function universalTeleport(targetCFrame)
	local rawText = inputBox.Text
	if rawText == "" or not targetCFrame then return end
	
	local targetNames = {}
	for _, n in ipairs(string.split(rawText, ",")) do
		local clean = string.gsub(n, "^%s*(.-)%s*$", "%1")
		if clean ~= "" then targetNames[clean] = true end
	end

	for _, obj in ipairs(workspace:GetDescendants()) do
		if targetNames[obj.Name] then
			if selectMode == "Part" and obj:IsA("BasePart") then
				obj.CFrame = targetCFrame
				if not obj.Anchored then
					obj.Velocity = Vector3.new(0,0,0)
					obj.RotVelocity = Vector3.new(0,0,0)
				end
			elseif selectMode == "Model" and obj:IsA("Model") then
				obj:PivotTo(targetCFrame)
				for _, p in ipairs(obj:GetDescendants()) do
					if p:IsA("BasePart") and not p.Anchored then
						p.Velocity = Vector3.new(0,0,0)
					end
				end
			end
		end
	end
end

